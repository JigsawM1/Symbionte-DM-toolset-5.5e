{
  "manifestVersion": 1,
  "name": "Pantalla de DM D&D 5.5e - ToolSet Es 5.5",
  "version": "1.0.0",
  "entryPoint": "/index.html",
  "about": {
    "authors": [
      "Antigravity"
    ],
    "description": "Pantalla de DM asimétrica y densa optimizada para TaleSpire y D&D 5.5e (2024)",
    "website": "https://github.com/PanoramicPanda/vite-react-symbiote"
  },
  "environment": {
    "capabilities": [
      "runInBackground"
    ],
    "extras": [
      "colorStyles"
    ],
    "loadTargetBehavior": "popup"
  },
  "api": {
    "version": "0.1",
    "subscriptions": {
      "symbiote": {
        "onStateChangeEvent": "manejarCambioEstadoSimbionte"
      },
      "creatures": {
        "onCreatureStateChange": "manejarCambioEstadoCriatura",
        "onCreatureSelectionChange": "manejarCambioSeleccionCriatura"
      },
      "initiative": {
        "onInitiativeEvent": "manejarEventoIniciativa"
      },
      "dice": {
        "onRollResults": "manejarResultadosDados"
      }
    }
  }
}
